{
  "sources": [
    "hackernews",
    "github-trending-today",
    "v2ex",
    "juejin",
    "36kr",
    "sspai"
  ],
  "scoring": {
    "weights": { "depth": 40, "trend": 35, "practical": 25 },
    "threshold": 6
  },
  "ai": {
    "provider": "openai",
    "model": "gpt-5.4",
    "batch_size": 20,
    "max_tokens": 3000
  },
  "cache": {
    "ttl_minutes": 30,
    "retention_days": 7
  }
}
